# ---- LLM model selection (provider:model_id, or a preset alias) ----
# Presets: gemini-flash, gemini-pro, llama-70b, llama-8b, deepseek-r1, qwen, mistral
ORCHESTRATOR_MODEL=google_genai:gemini-2.5-flash   # drives the tool-calling loop
ADVISOR_MODEL=google_genai:gemini-2.5-flash        # writes the final recommendation

# ---- API keys (set only the ones you actually use) ----
# Google AI Studio (free):  https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-ai-studio-key
# Groq Console (free):      https://console.groq.com/keys
GROQ_API_KEY=your-groq-key
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
